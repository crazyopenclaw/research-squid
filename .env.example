# Required for all deployments
ANTHROPIC_API_KEY=sk-ant-...
BRAVE_API_KEY=...
HIVE_API_KEY=...

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hiveresearch

# PostgreSQL
DATABASE_URL=postgresql://hive:hiveresearch@postgres:5432/hive

# Redis (Celery)
REDIS_URL=redis://redis:6379

# Optional — for GPU backend
GPU_BACKEND_REPO_ROOT=/data/repos

# Optional — for bio backend
OPENFOLD_API_KEY=...
OPENFOLD_API_URL=https://...

# Optional — observability
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com
